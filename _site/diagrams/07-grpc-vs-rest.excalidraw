    {"id":"title","type":"text","x":260,"y":20,"width":680,"height":44,"text":"REST vs gRPC — Inside the Cluster","fontSize":28,"fontFamily":1,"textAlign":"center","strokeColor":"#00BCD4","backgroundColor":"transparent","fillStyle":"solid","roughness":0,"opacity":100,"version":1,"seed":1},

