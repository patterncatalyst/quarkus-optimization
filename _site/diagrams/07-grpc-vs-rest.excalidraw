    {"id":"stream-arr-lbl","type":"text","x":955,"y":486,"width":200,"height":40,"text":"Response stream — continuous\nevery 1 second, no polling","fontSize":11,"fontFamily":1,"textAlign":"left","strokeColor":"#00BCD4","backgroundColor":"transparent","fillStyle":"solid","roughness":0,"opacity":100,"version":1,"seed":27},

    {"id":"bench-title","type":"text","x":60,"y":265,"width":540,"height":26,"text":"Benchmark — same Quarkus service, same JVM","fontSize":16,"fontFamily":1,"textAlign":"left","strokeColor":"#F5A623","backgroundColor":"transparent","fillStyle":"solid","roughness":0,"opacity":100,"version":1,"seed":28},

