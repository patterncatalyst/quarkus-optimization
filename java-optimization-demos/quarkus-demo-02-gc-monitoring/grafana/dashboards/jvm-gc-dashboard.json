  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "GC Pause Max (ms) \u2014 G1GC vs ZGC",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "description": "Max GC pause duration. G1GC has visible stop-the-world spikes; ZGC stays near-zero.",
      "datasource": {
        "type": "prometheus",
        "uid": "ext-prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "ext-prometheus"
          },
          "expr": "jvm_gc_pause_seconds_max{job=\"quarkus-g1gc\"} * 1000",
          "legendFormat": "G1GC max",
          "refId": "A",
          "instant": false
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "ext-prometheus"
          },
          "expr": "jvm_gc_pause_seconds_max{job=\"quarkus-zgc\"} * 1000",
          "legendFormat": "ZGC max",
          "refId": "B",
          "instant": false
        }
      ],
      "pluginVersion": "11.0.0"
    },
    {
      "id": 2,
      "title": "GC Pause Avg (ms) \u2014 G1GC vs ZGC",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "description": "Average GC pause = rate(sum) / rate(count) over 1 min.",
      "datasource": {
        "type": "prometheus",
        "uid": "ext-prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "ext-prometheus"
          },
          "expr": "rate(jvm_gc_pause_seconds_sum{job=\"quarkus-g1gc\"}[1m]) / rate(jvm_gc_pause_seconds_count{job=\"quarkus-g1gc\"}[1m]) * 1000",
          "legendFormat": "G1GC avg",
          "refId": "A",
          "instant": false
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "ext-prometheus"
          },
          "expr": "rate(jvm_gc_pause_seconds_sum{job=\"quarkus-zgc\"}[1m]) / rate(jvm_gc_pause_seconds_count{job=\"quarkus-zgc\"}[1m]) * 1000",
          "legendFormat": "ZGC avg",
          "refId": "B",
          "instant": false
        }
      ],
      "pluginVersion": "11.0.0"
    },
    {
      "id": 3,
